# LLM API configuration (supports any LLM API compatible with the OpenAI SDK)
# Recommended starter model: qwen-plus on Alibaba Bailian: https://bailian.console.aliyun.com/
# Costs can add up quickly; start with simulations under 40 rounds
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# ===== ZEP memory graph configuration =====
# The monthly free tier is enough for basic usage: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== Graphiti + Neo4j backend core =====
# Prompt 2 routes the Step 1 base graph build and artifact export path through
# the Graphiti + Neo4j seam. The broader read/query/runtime update lanes still
# use legacy Zep services until later cutover prompts replace them.
GRAPH_BACKEND=graphiti_neo4j
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_local_neo4j_password_here
GRAPHITI_EXTRACTION_MODEL=gpt-4.1-mini
GRAPHITI_EMBEDDING_MODEL=text-embedding-3-small
GRAPH_BACKEND_BATCH_SIZE=3
GRAPH_BACKEND_SEARCH_LIMIT=12
GRAPH_BACKEND_SCAN_LIMIT=250
GRAPH_BACKEND_RUNTIME_BATCH_SIZE=25

# ===== Probabilistic rollout flags (all default to false in backend/app/config.py) =====
# Enable these four flags together for the bounded local Step 2 through Step 5
# probabilistic path described in README.md and docs/local-probabilistic-operator-runbook.md.
PROBABILISTIC_PREPARE_ENABLED=false
PROBABILISTIC_ENSEMBLE_STORAGE_ENABLED=false
PROBABILISTIC_REPORT_ENABLED=false
PROBABILISTIC_INTERACTION_ENABLED=false

# Leave calibration off unless calibrated artifacts and wording are explicitly added.
CALIBRATED_PROBABILITY_ENABLED=false

# ===== Boosted LLM configuration (optional) =====
# If you do not use the boosted configuration, omit the variables below from your env file
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here
